{
  "id": "com.qqmusic.source",
  "name": "QQ音乐",
  "versionCode": 1,
  "versionName": "0.1.0",
  "author": "Replica0110",
  "description": "QQ音乐搜索源插件",
  "apiVersion": 1,
  "includeDirs": [
    "lib"
  ],
  "entry": "source.js",
  "capabilities": ["searchSongs", "getLyrics", "searchCovers"],
  "requiredHostApis": [
    "http.getText", 
    "http.postText", 
    "base64.encodeText",
    "base64.decodeText",
    "base64.decodeBytes",
    "base64.encodeBytes",
    "base64.dropBytes", 
    "compression.inflateBytesToText",
    "compression.inflateBase64ToText"
  ],
  "configFields": [
    {
      "key": "cover_size",
      "title": "封面大小",
      "summary": "QQ 音乐封面图片尺寸",
      "type": "dropdown",
      "required": true,
      "defaultValue": "1200",
      "options": [
        { "value": "500", "label": "500 x 500" },
        { "value": "800", "label": "800 x 800" },
        { "value": "1200", "label": "1200 x 1200" }
      ]
    }
  ],
  "metadataFields": [
    { "key": "title", "title": "Title", "group": "basic", "writeable": true, "defaultTarget": "TITLE", "defaultMode": "OVERWRITE" },
    { "key": "artist", "title": "Artist", "group": "basic", "writeable": true, "defaultTarget": "ARTIST", "defaultMode": "OVERWRITE" },
    { "key": "album", "title": "Album", "group": "basic", "writeable": true, "defaultTarget": "ALBUM", "defaultMode": "OVERWRITE" },
    { "key": "date", "title": "Date", "group": "basic", "writeable": true, "defaultTarget": "DATE", "defaultMode": "SUPPLEMENT" },
    { "key": "track_number", "title": "Track Number", "group": "basic", "writeable": true, "defaultTarget": "TRACK_NUMBER", "defaultMode": "SUPPLEMENT" },
    { "key": "cover_url", "title": "Cover", "group": "media", "writeable": true, "defaultTarget": "COVER", "defaultMode": "SUPPLEMENT" },
    { "key": "subtitle", "title": "Subtitle", "group": "extended", "writeable": true, "defaultTarget": "SUBTITLE", "defaultMode": "DISABLED", "targetOptions": ["SUBTITLE", "COMMENT"] },
    { "key": "replay_gain_track_gain", "title": "ReplayGain Track Gain", "group": "audio", "writeable": true, "defaultTarget": "CUSTOM", "defaultMode": "SUPPLEMENT" },
    { "key": "replay_gain_track_peak", "title": "ReplayGain Track Peak", "group": "audio", "writeable": true, "defaultTarget": "CUSTOM", "defaultMode": "SUPPLEMENT" },
    { "key": "replay_gain_reference_loudness", "title": "ReplayGain Reference Loudness", "group": "audio", "writeable": true, "defaultTarget": "CUSTOM", "defaultMode": "SUPPLEMENT" }
  ]
}

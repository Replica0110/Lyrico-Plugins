{
  "id": "com.qqmusic.source",
  "name": "QQ音乐",
  "versionCode": 2,
  "versionName": "0.1.1",
  "author": "Replica0110",
  "description": "QQ音乐搜索源插件",
  "apiVersion": 1,
  "includeDirs": [
    "lib"
  ],
  "icon": "icon.png",
  "entry": "source.js",
  "capabilities": [
    "searchSongs",
    "getLyrics",
    "searchCovers"
  ],
  "configFields": [
    {
      "key": "cover_size",
      "title": "封面大小",
      "summary": "QQ 音乐封面图片尺寸",
      "type": "dropdown",
      "required": true,
      "defaultValue": "1200",
      "options": [
        {
          "value": "500",
          "label": "500 x 500"
        },
        {
          "value": "800",
          "label": "800 x 800"
        },
        {
          "value": "1200",
          "label": "1200 x 1200"
        }
      ]
    }
  ],
  "minHostApiVersion": 1
}

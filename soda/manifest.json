{
  "id": "com.sodamusic.source",
  "name": "汽水音乐",
  "versionCode": 1,
  "versionName": "0.1.0",
  "author": "Replica0110",
  "description": "汽水音乐搜索源插件",
  "apiVersion": 1,
  "includeDirs": [
    "lib"
  ],
  "entry": "source.js",
  "capabilities": ["searchSongs", "getLyrics", "searchCovers"],
  "requiredHostApis": ["http.getText", "http.postText"],
  "metadataFields": [
    { "key": "title", "title": "Title", "group": "basic", "writeable": true, "defaultTarget": "TITLE", "defaultMode": "OVERWRITE" },
    { "key": "artist", "title": "Artist", "group": "basic", "writeable": true, "defaultTarget": "ARTIST", "defaultMode": "OVERWRITE" },
    { "key": "album", "title": "Album", "group": "basic", "writeable": true, "defaultTarget": "ALBUM", "defaultMode": "OVERWRITE" },
    { "key": "cover_url", "title": "Cover", "group": "media", "writeable": true, "defaultTarget": "COVER", "defaultMode": "SUPPLEMENT" },
    { "key": "soda_track_id", "title": "Track ID", "group": "internal", "writeable": false, "internal": true },
    { "key": "composer", "title": "Composer", "group": "extended", "writeable": true, "defaultTarget": "COMPOSER", "defaultMode": "SUPPLEMENT" },
    { "key": "lyricist", "title": "Lyricist", "group": "extended", "writeable": true, "defaultTarget": "LYRICIST", "defaultMode": "SUPPLEMENT" },
    { "key": "subtitle", "title": "Subtitle", "group": "extended", "writeable": true, "defaultTarget": "SUBTITLE", "defaultMode": "DISABLED", "targetOptions": ["SUBTITLE", "COMMENT"] },
    { "key": "genre", "title": "Genre", "group": "extended", "writeable": true, "defaultTarget": "GENRE", "defaultMode": "SUPPLEMENT" }
  ]
}

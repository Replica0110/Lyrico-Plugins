{
  "id": "com.kugou.source",
  "name": "酷狗音乐",
  "versionCode": 1,
  "versionName": "0.1.0",
  "author": "Replica0110",
  "description": "酷狗搜索源插件",
  "apiVersion": 1,
  "includeDirs": [
    "lib"
  ],
  "entry": "source.js",
  "capabilities": ["searchSongs", "getLyrics", "searchCovers"],
  "requiredHostApis": [
    "http.getText", 
    "http.postText",
    "crypto.md5",
    "base64.encodeText",
    "base64.decodeText",
    "base64.decodeBytes",
    "base64.encodeBytes",
    "base64.dropBytes",
    "compression.inflateBytesToText",
    "compression.inflateBase64ToText"
  ],
  "metadataFields": [
    {
      "key": "title",
      "title": "Title",
      "group": "basic",
      "writeable": true,
      "defaultTarget": "TITLE",
      "defaultMode": "OVERWRITE"
    },
    {
      "key": "artist",
      "title": "Artist",
      "group": "basic",
      "writeable": true,
      "defaultTarget": "ARTIST",
      "defaultMode": "OVERWRITE"
    },
    {
      "key": "album",
      "title": "Album",
      "group": "basic",
      "writeable": true,
      "defaultTarget": "ALBUM",
      "defaultMode": "OVERWRITE"
    },
    {
      "key": "date",
      "title": "Date",
      "group": "basic",
      "writeable": true,
      "defaultTarget": "DATE",
      "defaultMode": "SUPPLEMENT"
    },
    {
      "key": "cover_url",
      "title": "Cover",
      "group": "media",
      "writeable": true,
      "defaultTarget": "COVER",
      "defaultMode": "SUPPLEMENT"
    },
    {
      "key": "subtitle",
      "title": "Subtitle",
      "group": "extended",
      "writeable": true,
      "defaultTarget": "SUBTITLE",
      "defaultMode": "DISABLED",
      "targetOptions": ["SUBTITLE", "COMMENT"]
    },
    {
      "key": "hash",
      "title": "Hash",
      "group": "internal",
      "writeable": false,
      "internal": true
    }
  ]
}
